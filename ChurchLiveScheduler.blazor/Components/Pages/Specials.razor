@page "/specials"
@rendermode InteractiveServer

<h3>Specials</h3>

<button type="button" class="btn btn-primary" @onclick="() => EditSpecialAsync(new ViewModels.Special())">
    <i class="bi bi-plus-lg"></i>
    Create Special
</button>

@if (SpecialsList == null)
{
    <p><em>Loading...</em></p>
}
else
{
    @foreach (var special in SpecialsList)
    {
        <div class="container" @onclick="() => EditSpecialAsync(special)">
            <div class="row">
                <div class="col-8">
                    <h4>@special.Name</h4>
                </div>
                <div class="col-4">
                    <i class="bi bi-calendar-event"></i>
                    @special.Datetime?.ToString("MMMM d, yyyy 'at' h:mm tt")
                </div>
            </div>
        </div>
    }
}

<div class="offcanvas offcanvas-end" data-bs-backdrop="static" tabindex="-1" id="editCanvas" aria-labelledby="editCanvasLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="editCanvasLabel">@OffCanvasTitle</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <EditForm Model="SelectedSpecial" OnValidSubmit="SaveSpecialAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" @bind="SelectedSpecial!.Name" />
            </div>
            <div class="mb-3">
                <label for="time" class="form-label">Date</label>
                <input type="datetime-local" class="form-control" id="time" @bind="SelectedSpecial!.Datetime" />
            </div>
            <div id="actions">
                <input type="submit" class="btn btn-primary" value="Save" />
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas" aria-label="Close">Close</button>
            </div>
        </EditForm>
    </div>
</div>
